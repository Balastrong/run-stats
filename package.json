{
  "name": "run-stats-workspace",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm --filter run-stats build && pnpm -r check",
    "dev": "pnpm --filter run-stats build && pnpm --filter @run-stats/web dev",
    "dev:web": "pnpm --filter @run-stats/web dev",
    "dev:cli": "pnpm --filter run-stats dev",
    "pack:cli": "pnpm --filter run-stats pack",
    "start": "pnpm --filter @run-stats/web start",
    "start:cli": "pnpm --filter run-stats start",
    "test": "pnpm --filter run-stats build && pnpm -r test"
  }
}
