# Optional: override the default cached Garmin DI token location.
# GARMIN_TOKEN_FILE=/Users/you/.config/run-stats/garmin/garmin_tokens.json

# Required when serving the browser UI in production. Generate with: openssl rand -base64 32
# WEB_SESSION_SECRET=replace-with-at-least-32-random-characters
# PORT=3000
# Optional build-time Nitro deployment preset, such as vercel or netlify.
# NITRO_PRESET=node-server
